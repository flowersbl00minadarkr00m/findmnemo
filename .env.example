# Google Cloud OAuth 2.0 Desktop client ID. Configure locally; never commit actual values.
FINDMNEMO_GOOGLE_CLIENT_ID=
# Some Desktop clients require a secret. Leave blank when Google does not provide one.
FINDMNEMO_GOOGLE_CLIENT_SECRET=
VITE_LOCAL_COMPANION_ENABLED=true
# Optional absolute database override for isolated development or verification only.
FINDMNEMO_DATABASE_PATH=
# Optional project registry path for the SDD scanner. Keep machine-specific paths local.
FINDMNEMO_PROJECT_REGISTRY=
# Optional minimized telemetry target. Required only for an explicitly approved --write workflow.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
