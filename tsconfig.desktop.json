{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-desktop",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node", "electron"]
  },
  "include": ["desktop/main.ts", "desktop/preload.cts", "desktop/lifecycle/**/*.ts", "desktop/agent-activity/**/*.ts", "server/**/*.ts", "shared/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
